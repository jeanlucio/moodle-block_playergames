{{!
    @template block_playergames/paused

    Displays the paused state when the user has opted out of gamification.
    Mirrors block_playerhud's sidebar_rejoin.mustache visual pattern.

    @package block_playergames
    @copyright 2026 Jean Lúcio
    @license https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "str_paused": "Gamification is paused",
        "str_reactivate": "Reactivate",
        "url_reactivate": "#"
    }
}}
<div class="text-center py-3 bpg-paused">
    <div class="mb-2 text-muted opacity-50">
        <i class="fa fa-pause-circle fa-3x" aria-hidden="true"></i>
    </div>
    <p class="small text-muted mb-3">{{str_paused}}</p>
    <a href="{{url_reactivate}}" class="btn btn-primary btn-sm w-100 shadow-sm">
        <i class="fa fa-play me-1" aria-hidden="true"></i>{{str_reactivate}}
    </a>
</div>
